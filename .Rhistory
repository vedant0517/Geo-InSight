install.packages("ggplot2")
library(ggplot2)
data(mpg)
ggplot(mpg, aes(x = displ, y = hwy, color = class)) +
geom_point(size = 3, alpha = 0.7) +
labs(
title = "Engine Displacement vs Highway Mileage",
x = "Engine Displacement (liters)",
y = "Highway Miles per Gallon",
color = "Car Class"
) +
theme_minimal()
# Given values
mean_val <- 1200
sd_val <- 100
# 1. Probability that bulb lasts more than 1300 hours
prob_more_1300 <- 1 - pnorm(1300, mean = mean_val, sd = sd_val)
cat("P(X > 1300) =", prob_more_1300, "\n")
# 2. Probability that bulb lasts between 1100 and 1250 hours
prob_between <- pnorm(1250, mean = mean_val, sd = sd_val) -
pnorm(1100, mean = mean_val, sd = sd_val)
cat("P(1100 < X < 1250) =", prob_between, "\n")
# 3. 95th percentile
percentile_95 <- qnorm(0.95, mean = mean_val, sd = sd_val)
cat("95th percentile =", percentile_95, "\n")
