roll_no <- 1:20
name <- c("Aarav","Diya","Rohan","Sneha","Kunal","Pooja","Aditya","Neha",
"Rahul","Ananya","Vikram","Isha","Siddharth","Meera","Arjun",
"Kavya","Nikhil","Ritu","Sanjay","Priya")
department <- c("CSE","IT","CSE","ENTC","IT","CSE","MECH","CSE",
"ENTC","IT","MECH","CSE","IT","ENTC","MECH",
"CSE","IT","ENTC","MECH","CSE")
marks_matrix <- matrix(c(
78,85,69,72,
88,91,84,86,
65,70,60,68,
74,79,73,77,
81,83,78,80,
69,72,70,71,
90,88,85,87,
76,74,79,75,
68,65,70,66,
92,90,94,91,
71,73,69,72,
85,88,86,87,
79,81,77,80,
66,68,64,67,
83,85,82,84,
91,93,89,92,
75,77,74,76,
70,72,68,71,
88,86,84,85,
80,82,79,81
), nrow = 20, byrow = TRUE)
colnames(marks_matrix) <- c("Maths","Physics","Chemistry","English")
student_df <- data.frame(
Roll_No = roll_no,
Name = name,
Department = department,
marks_matrix
)
print(student_df)
student_df$Student_Average <- rowMeans(student_df[,4:7])
print(student_df[, c("Name","Student_Average")])
print(student_df)
subject_average <- colMeans(student_df[,4:7])
print(subject_average)
print(student_df)
class_average <- mean(student_df$Student_Average)
above_average_students <- student_df[
student_df$Student_Average > class_average,
c("Roll_No","Name","Department","Student_Average")
]
print(above_average_students)
emp_id <- c(101:115)
salary <- c(60000,25000,45000,48000,35000,
62000,27000,50000,36000,47000,
26000,65000,52000,38000,28000)
employee_list <- list(
Emp_ID = emp_id,
Name = c("Ramesh","Suresh","Anita","Kiran","Neelam",
"Vivek","Pallavi","Amit","Sunita","Rohit",
"Manoj","Seema","Alok","Priyanka","Deepak"),
Designation = c("Manager","Clerk","Engineer","Engineer","HR",
"Manager","Clerk","Engineer","HR","Engineer",
"Clerk","Manager","Engineer","HR","Clerk"),
Department = c("Admin","Accounts","IT","IT","HR",
"Admin","Accounts","IT","HR","IT",
"Accounts","Admin","IT","HR","Accounts"),
Monthly_Salary = salary
)
employee_df <- data.frame(employee_list)
print(employee_df)
employee_df$Annual_Salary <- employee_df$Monthly_Salary * 12
employee_df$Salary_Grade <- cut(
employee_df$Monthly_Salary,
breaks = c(0,30000,50000,70000),
labels = c("Low","Medium","High")
)
print(employee_df)
